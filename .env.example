# =============================================================================
# Shopanda — Environment Variables
# =============================================================================
# Copy this file to .env and adjust values for your environment.
# Every variable here has a sensible default in configs/config.yaml.
# Env vars take precedence over YAML values.
#
# Alternatively, set DATABASE_URL for a full PostgreSQL DSN:
#   DATABASE_URL=postgres://user:pass@host:5432/shopanda?sslmode=disable
# =============================================================================

# === Server ===
SHOPANDA_SERVER_HOST=0.0.0.0
SHOPANDA_SERVER_PORT=8080
# Public URL clients use to reach this server (required when host is 0.0.0.0).
# Defaults scheme to https if omitted. No trailing slash.
SHOPANDA_SERVER_PUBLIC_BASE_URL=https://shop.example.com

# === Database (PostgreSQL) ===
SHOPANDA_DATABASE_HOST=localhost
SHOPANDA_DATABASE_PORT=5432
SHOPANDA_DATABASE_USER=shopanda
SHOPANDA_DATABASE_PASSWORD=changeme
SHOPANDA_DATABASE_NAME=shopanda
SHOPANDA_DATABASE_SSLMODE=disable

# === Logging ===
# Levels: debug, info, warn, error
# Formats: json, text
SHOPANDA_LOG_LEVEL=info
SHOPANDA_LOG_FORMAT=json

# === Authentication ===
# REQUIRED — app refuses to start without it.
# Generate with: openssl rand -hex 32
SHOPANDA_AUTH_JWT_SECRET=
# Token lifetime (Go duration: 24h, 720h, etc.)
SHOPANDA_AUTH_JWT_TTL=24h

# === Mail (SMTP) ===
SHOPANDA_MAIL_DRIVER=smtp
SHOPANDA_MAIL_SMTP_HOST=localhost
SHOPANDA_MAIL_SMTP_PORT=587
SHOPANDA_MAIL_SMTP_USER=
SHOPANDA_MAIL_SMTP_PASSWORD=
SHOPANDA_MAIL_SMTP_FROM=noreply@example.com

# === Media Storage ===
# Drivers: local (default), s3 (future)
SHOPANDA_MEDIA_STORAGE=local
SHOPANDA_MEDIA_LOCAL_BASE_PATH=./public/media
SHOPANDA_MEDIA_LOCAL_BASE_URL=/media

# === Cache ===
# Drivers: postgres (default)
SHOPANDA_CACHE_DRIVER=postgres

# === Frontend (optional SSR storefront) ===
SHOPANDA_FRONTEND_ENABLED=false
SHOPANDA_FRONTEND_MODE=ssr
SHOPANDA_FRONTEND_THEME_PATH=themes/default

# === CDN (optional) ===
# When set, asset URLs use this as base instead of local paths.
SHOPANDA_CDN_BASE_URL=

# === Webhooks ===
# Per-provider secrets. Replace PROVIDER with uppercase provider name.
# SHOPANDA_WEBHOOKS_SECRET_STRIPE=whsec_...
# SHOPANDA_WEBHOOKS_SECRET_PAYPAL=...

# === Rate Limiting ===
SHOPANDA_RATE_LIMIT_ENABLED=false
# Tokens per second (0 = unlimited)
SHOPANDA_RATE_LIMIT_DEFAULT_RATE=10
# Max burst (concurrent requests)
SHOPANDA_RATE_LIMIT_DEFAULT_BURST=20

# === Seeding (used only by `app seed`) ===
SHOPANDA_SEED_ADMIN_PASSWORD=changeme

# === Development ===
# Set to any value to enable dev mode (e.g. logs password reset tokens)
# SHOPANDA_DEV_MODE=1

# === Testing ===
# PostgreSQL DSN for integration tests (tests skip if unset)
# SHOPANDA_TEST_DSN=postgres://shopanda:shopanda@localhost:5432/shopanda_test?sslmode=disable
